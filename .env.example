# Copy to .env and fill in real values. Never commit .env itself.

# Postgres
POSTGRES_PASSWORD=

# Backend auth
SECRET_KEY=
INITIAL_ADMIN_PASSWORD=

# Frontend origin (used for CORS + links in emails/WhatsApp messages)
FRONTEND_URL=http://localhost:5173

# Google Calendar sync — see backend/scripts/gcal_auth.py for how to obtain these
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_PROSPECTOS=
GOOGLE_CALENDAR_PENDIENTE=
GOOGLE_CALENDAR_ABONO=
GOOGLE_CALENDAR_OK=
GOOGLE_CALENDAR_OBSEQUIO=
GOOGLE_CALENDAR_PUBLICIDAD=
